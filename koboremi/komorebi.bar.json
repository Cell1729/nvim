 {
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.30/schema.bar.json",
  "monitor": 0,
  "work_area_offset": {
    "left": 15,
    "top": 15,
    "right": 15,
    "bottom": 0
  },
  "font_family": "PlemolJP Console HS",
  "theme": {
    "palette": "Base16",
    "name": "Ocean"
  },
  "left_widgets": [
    {
      "Komorebi": {
	"focused_window": {
	  "enable": true,
	  "show_icon": true
	},
        "workspaces": {
          "enable": true,
          "hide_empty_workspaces": false
        },
        "layout": {
          "enable": true
        }
      }
    }
  ],
 "right_widgets": [
    {
      "Media": { 
        "enable": true,
        "show_activity": true,
        "show_title": true,
        "show_artist": true
      }
    },
    {
      "Date": {
        "enable": true,
        "format": "YearMonthDate"
      }
    },
    {
      "Time": {
        "enable": true,
        "format": "TwentyFourHour"
      }
    }
  ]
}
